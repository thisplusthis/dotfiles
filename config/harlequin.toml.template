# Harlequin SQL IDE Configuration
# This is a TEMPLATE — credentials come from environment variables
# See: install-harlequin.sh for setup instructions

default_profile = "atlas"

[profiles.atlas]
type = "mysql"
host = "${HARLEQUIN_HOST}"
port = ${HARLEQUIN_PORT}
user = "${HARLEQUIN_USER}"
password = "${HARLEQUIN_PASSWORD}"
database = "${HARLEQUIN_DATABASE}"
theme = "monokai"
